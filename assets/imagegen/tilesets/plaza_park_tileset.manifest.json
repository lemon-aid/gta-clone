  "rules": {
    "bench": "Use bench cells 24-27 as solid props with a sitAnchorPx. To sit, place the character centered on sitAnchorPx and draw character after bench backrest when needed.",
    "statue": "Cells 33 and 34 are plaza focal props; keep at least one walkable tile around them.",
    "fountain": "Cell 32 is a large solid focal prop; use cell 47 as terrain base underneath for a plaza center.",
    "paths": "Use cells 40-47 for connected plaza walk paths over grass.",
    "parks": "Place trees and large props on grass/path edges, not blocking all routes through the plaza."
  }
